#!/bin/sh
# MOOR configure script
# Detects compiler, libsodium, zlib, and generates config.mk

set -e

PREFIX="/usr/local"
BINDIR=""
SYSCONFDIR=""
CC=""
EXTRA_CFLAGS=""
EXTRA_LDFLAGS=""

usage() {
    cat <<EOF
Usage: ./configure [options]

Options:
  --prefix=DIR         Install prefix [/usr/local]
  --bindir=DIR         Binary directory [PREFIX/bin]
  --sysconfdir=DIR     Config file directory [PREFIX/etc]
  CC=<compiler>        C compiler to use [auto-detect]
  CFLAGS=<flags>       Extra compiler flags
  LDFLAGS=<flags>      Extra linker flags
  --help               Show this help
EOF
    exit 0
}

# Parse arguments
for arg in "$@"; do
    case "$arg" in
        --prefix=*)    PREFIX="${arg#*=}" ;;
        --bindir=*)    BINDIR="${arg#*=}" ;;
        --sysconfdir=*) SYSCONFDIR="${arg#*=}" ;;
        CC=*)          CC="${arg#*=}" ;;
        CFLAGS=*)      EXTRA_CFLAGS="${arg#*=}" ;;
        LDFLAGS=*)     EXTRA_LDFLAGS="${arg#*=}" ;;
        --help|-h)     usage ;;
        *)
            echo "Unknown option: $arg"
            echo "Try './configure --help' for usage."
            exit 1
            ;;
    esac
done

[ -z "$BINDIR" ] && BINDIR="$PREFIX/bin"
[ -z "$SYSCONFDIR" ] && SYSCONFDIR="$PREFIX/etc"

echo "Configuring MOOR v0.7.0..."
echo ""
echo "  prefix:      $PREFIX"
echo "  bindir:      $BINDIR"
echo "  sysconfdir:  $SYSCONFDIR"

# Detect compiler
if [ -z "$CC" ]; then
    for c in gcc clang cc; do
        if command -v "$c" >/dev/null 2>&1; then
            CC="$c"
            break
        fi
    done
fi

if [ -z "$CC" ]; then
    echo "ERROR: no C compiler found. Install gcc or clang."
    exit 1
fi

echo "  CC:          $CC"

# Verify compiler works
cat > /tmp/moor_conftest.c <<EOF
int main(void) { return 0; }
EOF
if ! "$CC" -o /tmp/moor_conftest /tmp/moor_conftest.c 2>/dev/null; then
    echo "ERROR: $CC cannot compile a simple program."
    rm -f /tmp/moor_conftest.c /tmp/moor_conftest
    exit 1
fi
rm -f /tmp/moor_conftest.c /tmp/moor_conftest

# Check libsodium
SODIUM_CFLAGS=""
SODIUM_LIBS=""
if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists libsodium 2>/dev/null; then
    SODIUM_CFLAGS="$(pkg-config --cflags libsodium)"
    SODIUM_LIBS="$(pkg-config --libs libsodium)"
    # Add rpath for non-standard lib dirs so runtime linker finds it
    _sodium_libdir="$(pkg-config --variable=libdir libsodium 2>/dev/null)"
    case "$_sodium_libdir" in
        /usr/lib|/usr/lib64|/lib|/lib64|"") ;;
        *) SODIUM_LIBS="$SODIUM_LIBS -Wl,-rpath,$_sodium_libdir" ;;
    esac
    echo "  libsodium:   yes (pkg-config)"
else
    # Try manual detection
    cat > /tmp/moor_conftest.c <<EOF
#include <sodium.h>
int main(void) { return sodium_init(); }
EOF
    if "$CC" -o /tmp/moor_conftest /tmp/moor_conftest.c -lsodium 2>/dev/null; then
        SODIUM_LIBS="-lsodium"
        echo "  libsodium:   yes (manual)"
    else
        echo "ERROR: libsodium not found. Install libsodium-dev."
        rm -f /tmp/moor_conftest.c /tmp/moor_conftest
        exit 1
    fi
    rm -f /tmp/moor_conftest.c /tmp/moor_conftest
fi

# Check zlib
ZLIB_CFLAGS=""
ZLIB_LIBS=""
if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists zlib 2>/dev/null; then
    ZLIB_CFLAGS="$(pkg-config --cflags zlib)"
    ZLIB_LIBS="$(pkg-config --libs zlib)"
    echo "  zlib:        yes (pkg-config)"
else
    cat > /tmp/moor_conftest.c <<EOF
#include <zlib.h>
int main(void) { return (int)zlibVersion()[0]; }
EOF
    if "$CC" -o /tmp/moor_conftest /tmp/moor_conftest.c -lz 2>/dev/null; then
        ZLIB_LIBS="-lz"
        echo "  zlib:        yes (manual)"
    else
        echo "ERROR: zlib not found. Install zlib1g-dev."
        rm -f /tmp/moor_conftest.c /tmp/moor_conftest
        exit 1
    fi
    rm -f /tmp/moor_conftest.c /tmp/moor_conftest
fi

# Write config.mk
cat > config.mk <<EOF
# Generated by ./configure — do not edit
PREFIX = $PREFIX
BINDIR = $BINDIR
SYSCONFDIR = $SYSCONFDIR
CC = $CC
SODIUM_CFLAGS = $SODIUM_CFLAGS
SODIUM_LIBS = $SODIUM_LIBS
ZLIB_CFLAGS = $ZLIB_CFLAGS
ZLIB_LIBS = $ZLIB_LIBS
EXTRA_CFLAGS = $EXTRA_CFLAGS
EXTRA_LDFLAGS = $EXTRA_LDFLAGS
EOF

echo ""
echo "Configuration summary:"
echo "  CC:          $CC"
echo "  libsodium:   yes"
echo "  zlib:        yes"
echo "  prefix:      $PREFIX"
echo "  bindir:      $BINDIR"
echo "  sysconfdir:  $SYSCONFDIR"
echo ""
echo "Configuration written to config.mk"
echo "Run 'make' to build, 'sudo make install' to install."
